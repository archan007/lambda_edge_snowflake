{
  "_comment": "Attach to the IAM user/role whose access key is stored as AWS_ACCESS_KEY_ID_PROD.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEdgeLambdaUpdates",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:PublishVersion",
        "lambda:GetFunction"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:123456789012:function:snowflake-api-edge-viewer-request-prod",
        "arn:aws:lambda:us-east-1:123456789012:function:snowflake-api-edge-origin-request-prod"
      ]
    }
  ]
}
