{
  "_comment": "PROD execution policy for snowflake-api-edge-role-prod. Allows the PROD edge lambdas to invoke ONLY the PROD core lambda.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowInvokeCoreLambdaProd",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:snowflake-api-core-prod"
    },
    {
      "Sid": "AllowCloudWatchLogsInAllRegions",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/us-east-1.*:*"
    }
  ]
}
