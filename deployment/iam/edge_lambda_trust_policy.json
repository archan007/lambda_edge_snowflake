{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowLambdaAndEdgeLambdaToAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "Service": [
          "lambda.amazonaws.com",
          "edgelambda.amazonaws.com"
        ]
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
